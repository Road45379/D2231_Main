#include "TurnPlate_1.h"
#include "Gloable_Schema.h"

#define MOTOR_RESET				   0x03//电机复位

void TurnPlate_1_Module_ResetMotor(NetCmd *cmd)//转盘1_复位电机
{
	if(_State_Moudle.State_Manipulator == State_NoBusy)
	{
		_State_Moudle.State_Manipulator = State_Busy;

		//电爪复位
		UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_hand, MOTOR_COM_RESET, 0);
		ManipulatorModule_Num = STEP_1;
	}else
	{
		if(ManipulatorModule_Num == STEP_1)
		{

		}
	}
}

void TurnPlate_1_Module(NetCmd *cmd)
{
	switch(cmd->code){
	case MOTOR_RESET://复位
		TurnPlate_1_Module_ResetMotor(cmd);
		break;

	}
}


