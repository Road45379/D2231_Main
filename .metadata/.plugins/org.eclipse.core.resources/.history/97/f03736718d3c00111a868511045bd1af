#include "PublicCommand.h"
#include "Set_Time.h"
#include "TurnPlate_2_OP.h"
#include "ControlBoard.h"
#include "TurnPlate_3_OP.h"

NetCmd *ParsingStringToNetCmd_NetCmd_Public = NULL;//主控解析指令

void PublicCommand(char *buff)
{
	static int i = 0;
	if(i == 0)//第一次调用该函数的时候初始化一下结构体
	{
		ParsingStringToNetCmd_NetCmd_Public = (NetCmd *) malloc(sizeof(NetCmd));//主控解析指令
		i = 1;
	}
	ParsingStringToNetCmd(buff, ParsingStringToNetCmd_NetCmd_Public);
	switch(ParsingStringToNetCmd_NetCmd_Public->code){
		case 0x01://读版本
		{
			Eth_Send_Queue(ParsingStringToNetCmd_NetCmd_Public, 0, 0xFF, 3, 0x0000, Version1, Version2);
		}
		break;
	case 0x03://整机复位
		if(_State_Moudle.State_DeviceReset == 2)
		{
			Eth_Send_Queue(ParsingStringToNetCmd_NetCmd_Public, 0, 0xFF, 1, 0x0000);
			break;
		}
		if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[2]) == 0)//常规复位
		{
			reset = 0;
		}else if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[2]) == 1)//急停
		{

		}else if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[2]) == 2)//启动
		{

		}
		_NetCmd_reset = (NetCmd *) malloc(sizeof(NetCmd));
		memcpy(_NetCmd_reset, ParsingStringToNetCmd_NetCmd_Public, sizeof(NetCmd));
		Turntable_2_trunNum = 0;
		Turntable_2_lastLocatin = 1;
		Turntable_3_trunNum = 0;
		Turntable_3_lastLocatin = 1;
		_State_Moudle.State_DeviceReset = 2;//整机状态-正在复位
		break;
	case 0x07://读写参数
		if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[0]) == 1)//写参数
		{
			if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[1]) == 1)//网络参数
			{
				unsigned int pvarlength = PackWord((char*) &ParsingStringToNetCmd_NetCmd_Public->pvar[2]);
				char IP[4096] = "0";
				int n = 0;
				int i = 0;
				for(i = 0; i < pvarlength;)
				{
					IP[n] = PackByte((char*) &ParsingStringToNetCmd_NetCmd_Public->pvar[6 + i]);
					i = i+2;
					n++;
				}
				memcpy(_NetInfo, IP, sizeof(NetInfo));
				char ch0xFF[4096] = "";
				memset(ch0xFF, 0, sizeof(ch0xFF));
				sprintf(ch0xFF, "%d.%d.%d.%d",_NetInfo->ip[0], _NetInfo->ip[1],_NetInfo->ip[2],_NetInfo->ip[3]);
				PutIniKeyString("IPCONFIG", "IPADDR", ch0xFF, Filename_IP);
				memset(ch0xFF, 0, sizeof(ch0xFF));
				sprintf(ch0xFF, "%02X%02X%02X",_NetInfo->mac[3],_NetInfo->mac[4],_NetInfo->mac[5]);
				SaveToFile(Filename_MAC, ch0xFF);
				char send_buf0x07[16] = "";
				strncat(send_buf0x07, (char*)&ParsingStringToNetCmd_NetCmd_Public->pvar[2], 4);
				Eth_Send_Queue(ParsingStringToNetCmd_NetCmd_Public, 0, 0xFF, 2, 0x0000, send_buf0x07);
			}
		}else//读参数
		{
			if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[1]) == 1)//网络参数
			{
				char s[1024] = "";
				ReadPointConfigure("IPCONFIG", "IPADDR", Filename_IP, s);
				const char a[2] = ".";
				char buf1[9] = {0};
				char buf2[9] = {0};
				char buf3[9] = {0};
				sprintf(buf1, "%02X%02X%02X%02X", atoi(strtok(s, a)),  atoi(strtok(NULL, a)),  atoi(strtok(NULL, a)),  atoi(strtok(NULL, a)));
				memset(s, 0, 1024);
				ReadForFile(Filename_MAC, s);
				int mac = htoi(s);
				sprintf(buf2, "000000%02X", (mac & 0xFF0000) >> 16);
				sprintf(buf3, "%02X%02X0000", (mac & 0xFF00) >> 8, (mac & 0xFF));

				Eth_Send_Queue(ParsingStringToNetCmd_NetCmd_Public, 0, 0xFF, 4, 0x0000, buf1, buf2, buf3);
			}
		}
		break;
	case 0x0C://设置模式
	{
		Set_Device_Mode(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[0]));
		if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[0]) == 2 || AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[0]) == 6)//测试模式，清空链表
		{
			ClearList(&list);
		}
		//设置分控模式
		int ControlBoard_Mode = AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[0]);
		switch(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[0])){
		case 0x03:
		case 0x04:
			ControlBoard_Mode = 1;
			break;
		case 0x05:
			ControlBoard_Mode = 3;
			break;
		case 0x06:
			ControlBoard_Mode = 4;
			break;
		}
		int err = 0;
		err = ControlBoard_Set_Mode(ControlBoard_1_ModuleCommandAdd, ControlBoard_Mode);
		err += ControlBoard_Set_Mode(ControlBoard_2_ModuleCommandAdd, ControlBoard_Mode);
		if(err == 0)
		{
			if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[0]) == 4)//小车自检模式，后带8个字符的“小车数量”
			{
				putInAsyncCmd(&asyncCmdlist, *ParsingStringToNetCmd_NetCmd_Public);
				Set_Car_Amount(Pack8Byte((char *)&ParsingStringToNetCmd_NetCmd_Public->pvar[1]));
			}
			else
			{
				Eth_Send_Queue(ParsingStringToNetCmd_NetCmd_Public, 0, 0xFF, 1, 0x0000);
			}
		}else
		{
			//报错
		}

		break;
	}
	case 0x0A://写系统时间
	{
		if(ParsingStringToNetCmd_NetCmd_Public->cnt != 14){
			printf("Master 0A parameter error\r\n");
			return;
		}
		SetSysTime(ParsingStringToNetCmd_NetCmd_Public->pvar, "%Y%m%d%H%M%S");

		char buf_readtime[64] = "";
		ReadSysTime(buf_readtime,"%Y%m%d%H%M%S");
		char buf1[9] = "";
		char buf2[9] = "";
		memcpy(buf1, buf_readtime, 8);
		memcpy(buf2, buf_readtime + 8, 6);
		memcpy(buf2, buf_readtime + 8, 7);
		strcat(buf2, "0");

		Eth_Send_Queue(ParsingStringToNetCmd_NetCmd_Public, 0, 0xFF, 3, 0x0000, buf1, buf2);
		break;
	}
	case 0x0D:
	{
		char carNum = AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[0]);
		SetTurntableRespond(carNum);
		int err = 0;
		err += ControlBoard_Turntable_Respond(ControlBoard_1_ModuleCommandAdd, carNum);
		err += ControlBoard_Turntable_Respond(ControlBoard_2_ModuleCommandAdd, carNum);
		if(err == 0)
		{
			Eth_Send_Queue(ParsingStringToNetCmd_NetCmd_Public, 0, 0xFF, 1, 0x0000);
		}else
		{
			//报错
		}
		break;
	}
	case 0x13://分支释放

		break;
	}
}
