#include "Gloable_Schema.h"

NetCmd *ParsingStringToNetCmd_NetCmd_Public = NULL;//主控解析指令

void PublicCommand(char *buff)
{
	static int i = 0;
	if(i == 0)//第一次调用该函数的时候初始化一下结构体
	{
		ParsingStringToNetCmd_NetCmd_Public = (NetCmd *) malloc(sizeof(NetCmd));//主控解析指令
		i = 1;
	}
	ParsingStringToNetCmd(buff, ParsingStringToNetCmd_NetCmd_Public);
	switch(ParsingStringToNetCmd_NetCmd_Public->code){
	case 0x03://整机复位
		if(_State_Moudle.State_DeviceReset == 2)
		{
			FinishRecv(ParsingStringToNetCmd_NetCmd_Public, 0, 0xFF, 1, 0x0000);
			break;
		}
		if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[2]) == 1)//常规复位
		{
			reset = 0;
		}else if(AsciiToHex(ParsingStringToNetCmd_NetCmd_Public->pvar[2]) == 2)//急停
		{

		}
		_State_Moudle.State_DeviceReset = 2;//整机状态-正在复位
		break;
	}
}
