#include "ManipulatorModule.h"


#define SET_MAINIPULATOR_PLACE     0x11//ЩшжУЛњаЕЪжЮЛжУ
#define READ_MAINIPULATOR_PLACE    0x12//ЖСЛњаЕЪжЮЛжУ
#define READ_SET_HAND_PLACE    	   0x15//ЖСЕчзІЮЛжУ
#define MOTOR_FREE				   0x04//ЕчЛњЪЭЗХ



void ManipulatorModule_Set_Place(NetCmd *cmd)
{

	if(_State_Moudle.State_Manipulator == State_NoBusy)
	{
		_State_Moudle.State_Manipulator = State_Busy;
		ManipulatorModule_Num = STEP_1;

	}else
	{
		if(ManipulatorModule_Num == STEP_1)
		{
			//ЖСзІзгзДЬЌ
			if(UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_hand, HAND_COM_READSTATE, 0) != 0)
			{
				//гаЭЈбЖЙЪеЯЃЌБЈДэ
			}else{
				//ХаЖЯзІзгзДЬЌ
				switch(PackByte(_ControlBoard[fd_RS485_index_2].Motor[Manipulator_Mode_Motor_Add_hand].point))
				{
				case 0x01://МаЕН
				case 0x03://УЛгаМаГжЕНЧвДѓгкЩшЖЈМЋЯо03,МаГжЕНЧвЖЊСЫвВЪЧ03
					//ЫЩПЊКѓЬЇЦ№Zжс
					ManipulatorModule_Num = STEP_2;
					break;
				case 0x04://еХПЊЛђепе§дкМа,е§дкдЫаазДЬЌ04
					//МЬајЖСзІзгзДЬЌ
					break;
				case 0x05://еХПЊЭъГЩ05
					//ЬЇЦ№Zжс
					ManipulatorModule_Num = STEP_3;
					break;
				}
			}
		}else if(ManipulatorModule_Num == STEP_2)//ЗЂЫЭЫЩПЊзІзгжИСю
		{

			//ЫЩПЊзІзг
			if(UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_hand, HAND_COM_MOVEMENT,1, HAND_COM_MOVEMENT_PUTDOWN) != 0)
			{
				//гаЭЈбЖЙЪеЯЃЌБЈДэ
			}else{
				ManipulatorModule_Num = STEP_1;//ЗЕЛиЩЯвЛВНЃЌМЬајЖСзІзгзДЬЌ
			}
		}else if(ManipulatorModule_Num == STEP_3)//ЬЇЦ№Zжс
		{
			if(UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_z, MOTOR_COM_SETSTEPS,1, MOTOR_0_STEPS) != 0)
			{
				//гаЭЈбЖЙЪеЯЃЌБЈДэ
			}else
			{
				ManipulatorModule_Num = STEP_4;
			}
		}else if(ManipulatorModule_Num == STEP_4)//ЕШЬЇЦ№ZжсЭъГЩЃЌвЦЖЏX/Y
		{
			if(UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_z, MOTOR_COM_READ_IN_PLACE, 0) != 0)
			{
				//гаЭЈбЖЙЪеЯЃЌБЈДэ
			}else
			{
				if(PackByte(_ControlBoard[fd_RS485_index_2].Motor[Manipulator_Mode_Motor_Add_z].point) != 0x00)//0ЮЊвЦЖЏжа
				{
					/*ХаЖЯдЫЖЏзДЬЌЪЧЗёгаЙЪеЯ
					if()
					{

					}*/

					//вЦЖЏX/Y

					if(BIT(PackByte(&cmd->pvar[0]), 0))//XашвЊвЦЖЏ
					{
						char x_steps[8] = {0};
						memcpy(x_steps, &cmd->pvar[2], 8);
						UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_x, MOTOR_COM_SETSTEPS,1, x_steps);
					}
					if(BIT(PackByte(&cmd->pvar[0]), 1))//yашвЊвЦЖЏ
					{
						char y_steps[8] = {0};
						memcpy(y_steps, &cmd->pvar[10], 8);
						UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_y, MOTOR_COM_SETSTEPS,1, y_steps);
					}
					ManipulatorModule_Num = STEP_5;
				}

			}
		}else if(ManipulatorModule_Num == STEP_5)//ЕШX/YжсЭъГЩ
		{
			UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_x, MOTOR_COM_READ_IN_PLACE, 0);
			UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_y, MOTOR_COM_READ_IN_PLACE, 0);
			if(PackByte(_ControlBoard[fd_RS485_index_2].Motor[Manipulator_Mode_Motor_Add_x].point) != 0x00
					&& PackByte(_ControlBoard[fd_RS485_index_2].Motor[Manipulator_Mode_Motor_Add_x].point) != 0x00)//0ЮЊвЦЖЏжа
			{
				/*ХаЖЯдЫЖЏзДЬЌЪЧЗёгаЙЪеЯ
				if()
				{

				}*/


				//вЦЖЏZжс
				if(BIT(PackByte(&cmd->pvar[0]), 2))//ZашвЊвЦЖЏ
				{
					char z_steps[8] = {0};
					memcpy(z_steps, &cmd->pvar[18], 8);
					UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_z, MOTOR_COM_SETSTEPS,1, z_steps);
				}
				ManipulatorModule_Num = STEP_6;
			}
		}else if(ManipulatorModule_Num == STEP_6)//ЕШzжсЭъГЩ
		{
			if(UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_z, MOTOR_COM_READ_IN_PLACE, 0) != 0)
			{
				//гаЭЈбЖЙЪеЯЃЌБЈДэ
			}else
			{
				if(PackByte(_ControlBoard[fd_RS485_index_2].Motor[Manipulator_Mode_Motor_Add_z].point) != 0x00)//0ЮЊвЦЖЏжа
				{
					/*ХаЖЯдЫЖЏзДЬЌЪЧЗёгаЙЪеЯ
					if()
					{

					}*/

					//ЕчзІЖЏзї
					if(BIT(PackByte(&cmd->pvar[0]), 3))//ЕчзІашвЊвЦЖЏ
					{
						char hand_movement[8] = {0};
						memcpy(hand_movement, &cmd->pvar[27], 1);
						UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_hand, HAND_COM_MOVEMENT,1, hand_movement);
						ManipulatorModule_Num = STEP_7;
					}else
					{
						Eth_Send_Queue(cmd, 0, 0xFF, 1, 0000);
						_State_Moudle.State_Manipulator = State_NoBusy;
					}

				}
			}
		}else if(ManipulatorModule_Num == STEP_7)//ЕШЕчзІЭъГЩ
		{
			//ЖСзІзгзДЬЌ
			if(UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_hand, HAND_COM_READSTATE, 0) != 0)
			{
				//гаЭЈбЖЙЪеЯЃЌБЈДэ
			}else{
				//ХаЖЯзІзгзДЬЌ
				if(PackByte(_ControlBoard[fd_RS485_index_2].Motor[Manipulator_Mode_Motor_Add_hand].point) != 0x04)//еХПЊЛђепе§дкМа,е§дкдЫаазДЬЌ04
				{
					Eth_Send_Queue(cmd, 0, 0xFF, 1, 0000);
					_State_Moudle.State_Manipulator = State_NoBusy;
				}
			}
		}
	}
}

