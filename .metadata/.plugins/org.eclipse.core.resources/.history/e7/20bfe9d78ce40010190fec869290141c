#include "main.h"
#define SERVER_PORT 1000
#define LINSTNNUM 5

/*
 * 속潼貫零斤口
 */
void LoadPointConfigure(char *filename)
{
	FILE *fd;
	char *a="[POINT]\n02=\n";
	char *ManipulatorModePoint;
	char *TurnPlate_1_ModePoint;
	unsigned int pvarlength02 = 0;
	char point02[1024] = "0";
	if(NULL == (fd = fopen(filename, "r")))
	{
		fd = fopen(filename, "w");
		fputs(a,fd);
		fclose(fd);
	}else{
		fclose(fd);
		ManipulatorModePoint = GetIniKeyString("POINT", "02", filename);
		if(ManipulatorModePoint != NULL)
		{
			pvarlength02 = (PackWord(ManipulatorModePoint) * 2) + 4;
			int n = 0;
			int i = 0;
			for(i = 4; i < pvarlength02;)
			{
				point02[n] = PackByte(ManipulatorModePoint + i);
				i = i+2;
				n++;
			}
			memcpy(My_ClawsPos, point02, sizeof(ClawsPos));
		}
		TurnPlate_1_ModePoint = GetIniKeyString("POINT", "03", filename);
		if(TurnPlate_1_ModePoint != NULL)
		{
			pvarlength02 = (PackWord(ManipulatorModePoint) * 2) + 4;
			int n = 0;
			int i = 0;
			for(i = 4; i < pvarlength02;)
			{
				point02[n] = PackByte(ManipulatorModePoint + i);
				i = i+2;
				n++;
			}
			memcpy(My_ClawsPos, point02, sizeof(ClawsPos));
		}
	}
}

int main(int argc, char *argv[]) {
	Uart_Open();
	my_memset((int*)&_State_Moudle.State_TarskControlModule1, State_NoBusy, sizeof(State_Moudle)/sizeof(int));

	My_ClawsPos = (ClawsPos *) malloc(sizeof(ClawsPos)); //02
	turntableSamplePos = (SampleTurntablePos *) malloc(sizeof(SampleTurntablePos));

	LoadPointConfigure(Filename_config);

	int Server_socketID = 0;
	int Server_addrLength = 0;
	int Server_ret = 0;
	struct sockaddr_in Server_addr;
	//댔역socket
	Server_socketID = socket(AF_INET, SOCK_STREAM, 0);

	if (Server_socketID < 0)
	{
		printf("Server socket error!\r\n");
#ifdef SaveLog
		indexs += sprintf(&LogBuf[indexs], "Server socket error!\r\n");
#endif
		return -1;
	}
	//곬땍菱성돨IP、 PORT
	Server_addrLength = sizeof(Server_addr);
	bzero(&Server_addr, Server_addrLength);//놓迦뺏륩蛟포뒈囹
	Server_addr.sin_family = AF_INET;
	Server_addr.sin_port = htons(SERVER_PORT);
	Server_addr.sin_addr.s_addr = INADDR_ANY;
	Server_ret = bind(Server_socketID, (struct sockaddr *) &Server_addr,
			(socklen_t) Server_addrLength);
	if (Server_ret < 0)
	{
		printf("server bind error!\r\n");
#ifdef SaveLog
		indexs += sprintf(&LogBuf[indexs], "server bind error!\r\n");
#endif
		close(Server_socketID);
		return -1;
	}
	//솰桂
	Server_ret = listen(Server_socketID, LINSTNNUM);
	if (Server_ret < 0)
	{
		printf("server listen error!\r\n");
#ifdef SaveLog
		indexs += sprintf(&LogBuf[indexs], "server listen error!\r\n");
#endif
		close(Server_socketID);
		return -1;
	}
	printf("server listen success\r\n");
#ifdef SaveLog
		indexs += sprintf(&LogBuf[indexs], "server listen success\r\n");
#endif

	pthread_create(NULL, NULL, (void *) &RecvPC_thread, NULL);
	pthread_create(NULL, NULL, (void *) &DeviceTask_Thread, NULL);
	pthread_create(NULL, NULL, (void *) &Recv_Uart_thread, NULL);
	pthread_create(NULL, NULL, (void *) &Eth_Send_pyhread, NULL);

	while(1)
	{
		memset(&Server_addr, 0, Server_addrLength);
		int Socket_ID_tmp = accept(Server_socketID,
				(struct sockaddr *) &Server_addr,
				(socklen_t *) &Server_addrLength);

		printf("Server_socketID = %d\n", Server_socketID);
#ifdef SaveLog
		indexs += sprintf(&LogBuf[indexs], "Server_socketID = %d\n", Server_socketID);
#endif
		printf("Socket_ID = %d\n", Get_Socket_ID());
#ifdef SaveLog
		indexs += sprintf(&LogBuf[indexs], "Socket_ID = %d\n", Socket_ID);
#endif
		if (Socket_ID_tmp < 0)
		{
			printf("PORT: 1000 Environmental control server accept error!\r\n");
#ifdef SaveLog
		indexs += sprintf(&LogBuf[indexs], "PORT: 1000 Environmental control server accept error!\r\n");
#endif
			close(Socket_ID_tmp);
			continue;
		}
		else
		{
			if(Get_Socket_ID() > 0)
			{
				close(Get_Socket_ID());
				Set_Socket_ID(-1);
			}
			Set_Socket_ID(Socket_ID_tmp);
			printf(
					"PORT : 1000 Environmental control Client accept succeed; ip = %s : %d\n",
					inet_ntoa(Server_addr.sin_addr),
					ntohs(Server_addr.sin_port));
#ifdef SaveLog
		indexs += sprintf(&LogBuf[indexs], "PORT : 1000 Environmental control Client accept succeed; ip = %s : %d\n",
				inet_ntoa(Server_addr.sin_addr),
				ntohs(Server_addr.sin_port));
#endif
		}
		usleep(100000);
	}
	close(Get_Socket_ID());

	return EXIT_SUCCESS;
}
