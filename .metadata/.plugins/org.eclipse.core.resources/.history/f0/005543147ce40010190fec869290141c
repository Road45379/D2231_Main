#include "TurnPlate_1.h"
#include "Gloable_Schema.h"

#define MOTOR_RESET				   0x03//电机复位

enum
{
	TurnPlate_1_Mode_Motor_Add = 1 //转盘1电机
};

void TurnPlate_1_Module_ResetMotor(NetCmd *cmd)//转盘1_复位电机
{
	if(_State_Moudle.State_TurnPlate_1_Module == State_NoBusy)
	{
		_State_Moudle.State_TurnPlate_1_Module = State_Busy;

		//转盘复位
		UartSend(fd_RS485_index_1, TurnPlate_1_Mode_Motor_Add, MOTOR_COM_RESET, 0);
		TurnPlate_1_Module_Num = STEP_1;
	}else
	{
		if(TurnPlate_1_Module_Num == STEP_1)
		{
			//等转盘复位完成
			UartSend(fd_RS485_index_1, TurnPlate_1_Mode_Motor_Add, MOTOR_COM_READRESETSTATE, 0);
			if(PackByte(_ControlBoard[fd_RS485_index_1].Motor[TurnPlate_1_Mode_Motor_Add].point) == 0x01)//转盘复位完成，复位Z轴
			{
				UartSend(fd_RS485_index_2, Manipulator_Mode_Motor_Add_z, MOTOR_COM_RESET, 0);
				ManipulatorModule_Num = STEP_2;
			}
		}
	}
}

void TurnPlate_1_Module(NetCmd *cmd)
{
	switch(cmd->code){
	case MOTOR_RESET://复位
		TurnPlate_1_Module_ResetMotor(cmd);
		break;

	}
}


