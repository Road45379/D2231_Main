	case MOTOR_COM_READSTEPS://读取电机坐标
		MOTOR_READSTEPS_8005_Recv(_recv_mgstrt_8005);
		break;
	}
}


recv_mgstrt_8005 _recv_mgstrt_8005;
void Recv_UartToCom(char *buff, int Moudle_Add)
{
	char cmd_buf[16] = "";
	int len = strlen(buff);
	memset(cmd_buf, 0, sizeof(cmd_buf));
	_recv_mgstrt_8005.srcaddr = Moudle_Add;
	_recv_mgstrt_8005.motoraddr = PackByte(buff + 1);//电机地址
	_recv_mgstrt_8005.cmdnum = buff[3];//功能码

	_recv_mgstrt_8005.DLC = len - 4 - 6;//减去头（4）和CRC（4）和尾（2）
	if(_recv_mgstrt_8005.DLC > 0)
	{
		memcpy(_recv_mgstrt_8005.Data_H, buff + 4, _recv_mgstrt_8005.DLC);//数据
	}
}


/*
 * 接收解析
 * 返回: 1:队列为空, 2:出队失败, 0:解析成功,
 */
int RecvAnalysis(queue *_queue, int Moudle_Add, void (*ControlBoardRecv)(recv_mgstrt_8005*))
{
	char Recv_queue_buf[1024] = "";
	int ret = 0;
	if(isEmpityQueue(_queue) == 3)
	{
		memset(Recv_queue_buf, 0, sizeof(Recv_queue_buf));
		ret = deQueue(_queue, Recv_queue_buf);
		if(ret == 2)
		{
			if(CompareCRC_8005(Recv_queue_buf) == 0)
			{
				Recv_UartToCom(Recv_queue_buf, Moudle_Add);
				ControlBoardRecv(&_recv_mgstrt_8005);
				return 0;
			}
		}else{
			return 2;
		}
	}else
	{
		return 1;
	}
	return -1;
}

void *Recv_Uart_thread()
{
	while(1)
	{
		RecvAnalysis(PQueue_RecvUART4, fd_RS485_index_3, RS458_4_BoardRecv);
		RecvAnalysis(PQueue_RecvUART3, fd_RS485_index_2, RS458_3_BoardRecv);
		usleep(1);
	}
}
