void DataComUART1(unsigned char Dat, int id)
{
	if(Dat == '>')
	{
		recvUart1_n = 0;
		memset(recvUart1_cmdtmp, 0, 4096);
	}
	printf("%c", Dat);
	recvUart1_cmdtmp[recvUart1_n++] = Dat;
	if(Dat == 0x0A && recvUart1_cmdtmp[recvUart1_n - 2] == 0x0D)
	{
		printf("%s\r\n", recvUart1_cmdtmp);
		if(recvUart1_cmdtmp[0] != '>')
		{
			return;
		}
		printf("uart1 recv : %s\n", recvUart1_cmdtmp);
		//数据存入接收队列
		if(strlen(recvUart1_cmdtmp) < 4096)
		{
			enQueue(PQueue_RecvUART1, recvUart1_cmdtmp, strlen(recvUart1_cmdtmp));
		}
		recvUart1_n = 0;
		memset(recvUart1_cmdtmp, 0, sizeof(recvUart1_cmdtmp));
	}
	//printf("%c", Dat);
}


