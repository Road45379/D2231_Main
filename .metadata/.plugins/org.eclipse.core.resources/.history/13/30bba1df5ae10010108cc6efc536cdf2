/*
 * 串口发送函数
 * 成功返回发送的长度，失败返回 地址<< 8 && 命令号
 */
int UartSend(int Module_Add, int Motor_Add, char cmd_add, char* cmd_data)
{
	char send_crcbuf[8] = "";
	char sndbuf[1024];
	memset(sndbuf, '\0', sizeof(sndbuf));
	sprintf(sndbuf, "%c%02X%c%s", Cmd_Hand, Motor_Add, cmd_add, cmd_data);
	crc_check_8005((uint8_t *)sndbuf, send_crcbuf);
	strcat(sndbuf, send_crcbuf);
	strcat(sndbuf, "\r\n");
	struct timeval Time_UART_Send;
	struct timeval Time_UART_Now;
	int sendlen = 0;
	int index = 0;
	//bool i = false;
	for(index = 0; index < 3; index++)
	{
		gettimeofday(&Time_UART_Send, NULL);//获取发送时间
		printf("send : %s", sndbuf);
		sendlen = Uart16550_Send(Get_fd_RS485_115200(Module_Add), (uint8_t*)sndbuf, strlen(sndbuf));
		while(1)
		{
			gettimeofday(&Time_UART_Now, NULL);//获取当前时间
			if(_ControlBoard[Module_Add].Motor[Motor_Add].Send_OK[(int)(cmd_add - 'A')] == true)
			{
				_ControlBoard[Module_Add].Motor[Motor_Add].Send_OK[(int)(cmd_add - 'A')] = false;
				return 0;
			}
			if((1000000 * (Time_UART_Now.tv_sec - Time_UART_Send.tv_sec) + Time_UART_Now.tv_usec - Time_UART_Send.tv_usec) > 1000000)
			{
				break;
			}
			usleep(1);
		}
	}
	return -1;
}

