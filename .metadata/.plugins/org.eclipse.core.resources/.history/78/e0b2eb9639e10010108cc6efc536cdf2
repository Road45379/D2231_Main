#include "Track_Mode.h"
#define MOTOR_STARTORSTOP   0x11   //ษฯฮปป๚ึธม๎-น์ตภต็ป๚ฦ๔อฃ




void TarskControlModule_MotorStartOrStop(NetCmd *cmd)
{
	int start_or_stop = 0;
	start_or_stop = AsciiToHex(cmd->pvar[0]);//0 อฃึน ,1 ฦ๔ถฏ
	static int i = 0;
	if(_State_Moudle.State_TarskControlModule1 == State_NoBusy)
	{
		_State_Moudle.State_TarskControlModule1 = State_Busy;
		if(0 != UartSend(fd_RS485_index_3, Tarck_Mode_Motor_Add_1, MOTOR_COM_MOMENT_MODE, &cmd->pvar[0]))
		{
			Eth_Send_Queue(cmd, 0, 0xFF, 1, 0001);
			_State_Moudle.State_TarskControlModule1 = State_NoBusy;
			break;
		}
		i++;
	}else
	{
		if(i < Tarck_Mode_Motor_Add_48)
		{
			if(0 != UartSend(fd_RS485_index_3, Tarck_Mode_Motor_Add_1 + i, MOTOR_COM_MOMENT_MODE, &cmd->pvar[0]))
			{
				Eth_Send_Queue(cmd, 0, 0xFF, 1, 0001);
				_State_Moudle.State_TarskControlModule1 = State_NoBusy;
				break;
			}
			i++;
		}else
		{
			i = 0;
		}

	}
	Eth_Send_Queue(cmd, 0, 0xFF, 1, 0000);
	_State_Moudle.State_TarskControlModule1 = State_NoBusy;
}



void TarskControlModule(NetCmd *cmd)
{
	switch(cmd->code){
	case MOTOR_STARTORSTOP://น์ตภต็ป๚ฦ๔อฃ
		TarskControlModule_MotorStartOrStop(cmd);
		break;


	}
}
