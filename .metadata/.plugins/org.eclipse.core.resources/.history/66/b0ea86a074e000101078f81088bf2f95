#include "Track_Mode.h"
#define MOTOR_STARTORSTOP   0x11   //ษฯฮปป๚ึธม๎-น์ตภต็ป๚ฦ๔อฃ




void TarskControlModule_MotorStartOrStop(NetCmd *cmd)
{
	int start_or_stop = 0;
	start_or_stop = AsciiToHex(cmd->pvar[0]);//0 อฃึน ,1 ฦ๔ถฏ
	int i = 0;
	for(; i < Tarck_Mode_Motor_Add_48; i++)
	{
		if(1 != UartSend(Get_fd_RS485_115200(fd_RS485_index_3), fd_RS485_index_3, Tarck_Mode_Motor_Add_1 + i, MOTOR_MOMENT_MODE, &cmd->pvar[0]))
		{
			FinishRecv(cmd, 0, 0xFF, 1, 0001);
		}
		usleep(10000);
	}
	FinishRecv(cmd, 0, 0xFF, 1, 0000);
}



void TarskControlModule(NetCmd *cmd)
{
	switch(cmd->code){
	case MOTOR_STARTORSTOP:
		TarskControlModule_MotorStartOrStop(cmd);
		break;


	}
}
