#include"Uart550.h"
#include "EMIO.h"

#define	UART550_CLK		58982400
#define	UART550_FIFO_SIZE	16

#define  RBR 0x1000 //RO Receiver Buffer Register
#define  THR 0x1000 //WO Transmitter Holding Register
#define  IER 0x1004 //R/W Interrupt Enable Register
#define  IIR 0x1008 //RO Interrupt Identification Register
#define  FCR 0x1008 //WO FIFO Control Register
#define  FCR 0x1008 //RO FIFO Control Register
#define  LCR 0x100C //R/W Line Control Register
#define  MCR 0x1010 //R/W Modem Control Register
#define  LSR 0x1014 //R/W Line Status Register
#define  MSR 0x1018 //R/W Modem Status Register
#define  SCR 0x101C //R/W Scratch Register
#define  DLL 0x1000 //R/W Divisor Latch (Least Significant Byte) Register
#define  DLM 0x1004 //R/W Divisor Latch (Most Significant Byte) Register
typedef struct
{
	int8_t IsItemUsed;
	uint32_t PhyAddress;
	int8_t IsRs485;
	int8_t _485line;
	int32_t _IRQ;
	void (*callback)(uint8_t, int32_t);
	int32_t calbckpra;//
	int32_t IntAtchId;
	struct sigevent _sigevent;
#define TxBufLen 0x4000
#define TxBufMsk 0x3FFF
	uint8_t TxBuf[TxBufLen];
	volatile uint32_t TxSum;
	volatile uint32_t TxPoint;
	uint8_t RxBuf[256];
	volatile uint8_t Rxin;
	volatile uint8_t Rxout;
	uintptr_t VirBase;
} Dev16550;
volatile struct GPIO_Reg *m_GPIO_Reg;
uintptr_t m_EMIO_Addr = MAP_DEVICE_FAILED;
static Dev16550 _Dev16550[32];

static void EMIO_RS485Send(uint8_t _485line)
{
	if (m_EMIO_Addr == MAP_DEVICE_FAILED)
	{
		return;
	}
	m_GPIO_Reg->DATA_2 |= 0x1 << _485line;
}

static void EMIO_RS485Recv(uint8_t _485line)
{
	if (m_EMIO_Addr == MAP_DEVICE_FAILED)
	{
		return;
	}
	m_GPIO_Reg->DATA_2 = m_GPIO_Reg->DATA_2 & (~(0x1 << _485line));
}
void Uart550IntHandle(Dev16550 *dev);
static const struct sigevent *_isr_handler(void *arg, int32_t id)
{
	Dev16550 *dev = arg;
	InterruptMask(dev->_IRQ, dev->IntAtchId);
	Uart550IntHandle(dev);
	InterruptUnmask(dev->_IRQ, dev->IntAtchId);
	return (&dev->_sigevent);
}

void Uart550IntHandle(Dev16550 *dev)
{
	volatile uint32_t iir, rbr;
	if (dev == 0 || dev->VirBase == 0)
	{
		return;
	}
	iir = in32(dev->VirBase + IIR) & 0xF;
	if (iir & 0x1) //modem handle
	{
		in32(dev->VirBase + LSR);
	}
	else if (iir & 0x2) //Tx data handle
	{
		int32_t i, count = 0;
		out32(dev->VirBase + IER, in32(dev->VirBase + IER) & (~0x2));//close empty int
		if (in32(dev->VirBase + LSR) & 0x20)//txfifo empty
		{
			if (in32(dev->VirBase + IIR) & 0xC0)//0xC0:16550  0x00:16450
				count = UART550_FIFO_SIZE - 1;
			else
				count = 1;
		}
		if (dev->TxPoint < dev->TxSum)
		{
			for (i = 0; (i < count) && (dev->TxPoint < dev->TxSum); i++)
			{
				out32(dev->VirBase + THR, dev->TxBuf[dev->TxPoint & TxBufMsk]);
				dev->TxPoint++;
			}
			out32(dev->VirBase + IER, in32(dev->VirBase + IER) | 0x2);
		}
		else
		{
			//send done
			if (dev->IsRs485 == 0x55)
			{
				EMIO_RS485Recv(dev->_485line);
			}
		}
	}
	else if (iir & 0x4) //Rx data handle
	{
		while (in32(dev->VirBase + LSR) & 0x1)
		{
			rbr = in32(dev->VirBase + RBR);
			dev->RxBuf[dev->Rxin++] = rbr;
		}
	}
}
void* Uart550_int_thread(void *arg)
{
	ThreadCtl(_NTO_TCTL_IO, 0);
	Dev16550 *dev = arg;
	SIGEV_INTR_INIT(&(dev->_sigevent));
	dev->IntAtchId = InterruptAttach(dev->_IRQ, _isr_handler, arg, 0,
			_NTO_INTR_FLAGS_TRK_MSK);
	if (dev->IntAtchId == -1)
	{
		printf("ISR attach Error!\n");
		return NULL;
	}
	while (1)
	{
		InterruptWait(0, NULL);
		//Uart550IntHandle(dev);
		//InterruptUnmask(dev->_IRQ, dev->IntAtchId);
		while (dev->Rxin != dev->Rxout)
		{
			if (dev->callback != NULL)
			{
				dev->callback(dev->RxBuf[dev->Rxout], dev->calbckpra);
			}
			dev->Rxout++;
		}
	}
	return NULL;
}
static void Uart550RxFifoClr(int32_t fd)
{
	if (_Dev16550[fd].VirBase == 0)
	{
		return;
	}
	while (in32(_Dev16550[fd].VirBase + LSR) & 0x01)
	{
		in32(_Dev16550[fd].VirBase + RBR);
	}
}
/**
 * Function:       // Uart16550_Open
 * Description:    // 特定串口初始化
 * Input:* uint32_t PhyAddress,   //串口的物理地址 由硬件决定
 * int32_t IRQ,//串口的中断号 由硬件决定
 * int32_t BitRate,  //比特率 常见的有 9600 19200 38400 57600 115200 等等 根据需要填写
 * stopBits st,//停止位  [stopBits_1 表示一位停止位]     [stopBits_2  表示两位停止位]
 * Parity Pra,  //校验位  [Parity_None 没有校验]          [Parity_Odd  奇校验]             [Parity_Even 偶校验]
 * int8_t Is485Mode  //是否为485模式  0 为正常模式其他数为RS485模式
 * int32_t _485Line, //当为485模式时EMIO的线序号
 * void(*func_rcv)(unsigned char,int)//回调函数
 * int32_t id //回调函数回调时的第二个参数 不用则为0
 * Output:         // 无
 * Return:         // 成功则返回设备对应的设备号 否则返回-1
 * Others:         //无
 */
int32_t Uart16550_Open(uint32_t PhyAddress, int32_t IRQ, int32_t BitRate,
		stopBits st, Parity Pra, int8_t Is485Mode, int32_t _485Line,
		void(*func_rcv)(uint8_t, int32_t), int32_t usrdat)
{
	uint32_t divide;
	if (ThreadCtl(_NTO_TCTL_IO, 0) == -1)
	{
		printf("WRONG PERMISSION\n");
	}
	int32_t fd = -1;
	int32_t i = 0;
	//校验只能是下面枚举的这几个值
	if ((Pra == Parity_None) || (Pra == Parity_Odd) || (Pra == Parity_Even)
			|| (Pra == Parity_Mark) || (Pra == Parity_Sapce))
	{
		i |= 0x1;
	}
	if (st == stopBits_1 || st == stopBits_2)
	{
		i |= 0x2;
	}
	//BitRate = 460800;
	//BitRate 做一个宽泛的限制
	if (50 <= BitRate && BitRate < 4000000)
	{
		i |= 0x4;
	}
	if (i != 0x7)
	{
		return -1;
	}
	for (i = 0; i < sizeof(_Dev16550) / sizeof(Dev16550); i++)
	{
		if (_Dev16550[i].PhyAddress == PhyAddress)
		{//已经有程序打开了该端口
			return -2;
		}
	}
	for (i = 0; i < sizeof(_Dev16550) / sizeof(Dev16550); i++)
	{
		if (_Dev16550[i].IsItemUsed != 0x55)
		{
			fd = i;
			break;
		}
	}
	if (fd == -1)
	{
		return -2;
	}
	_Dev16550[fd].VirBase = mmap_device_io(0x1100, PhyAddress);
	if (_Dev16550[fd].VirBase == 0)
	{
		printf("Error in mmap UART550 %d\n", PhyAddress);
		return -3;
	}
	Uart550RxFifoClr(fd);
	_Dev16550[fd].TxPoint = 0;
	_Dev16550[fd].TxSum = 0;
	_Dev16550[fd].callback = func_rcv;
	_Dev16550[fd].calbckpra = usrdat;
#define DLAB_1 1 //Allows access to the Divisor Latch Registers and reading of the FIFO Control	Register
#define DLAB_0 0 //Allows access to RBR, THR, IER and IIR registers.
	out32(_Dev16550[fd].VirBase + LCR, (DLAB_1 << 7));
	float d = UART550_CLK;
	d = d / 16;
	d = d / BitRate;
	d = d + 0.5;
	divide = (int) d;
	//divide = (UART550_CLK / 16) / BitRate;
	out32(_Dev16550[fd].VirBase + DLM, (divide >> 8) & 0xFF);
	out32(_Dev16550[fd].VirBase + DLL, divide & 0xFF);
#define dataBits_8  0x3
#define dataBits_7  0x2
#define dataBits_6  0x1
	//#define dataBits_5  0x0
	out32(_Dev16550[fd].VirBase + LCR, (Pra << 3) | (st << 1) | dataBits_8);
#define RCVR_FIFO_TRI_Lev 0
#define FIFOEN 1
	out32(_Dev16550[fd].VirBase + FCR, (RCVR_FIFO_TRI_Lev << 6) | FIFOEN);//set fifo
	out32(_Dev16550[fd].VirBase + MCR, 0x0);//set option
#define ETBEI 1//Enable Transmitter Holding Register Empty	Interrupt.
#define ERBFI 1//Enable Received Data Available Interrupt
	out32(_Dev16550[fd].VirBase + IER, (ETBEI << 1) | ERBFI);
	_Dev16550[fd]._IRQ = IRQ;//;
	_Dev16550[fd].PhyAddress = PhyAddress;
	if (Is485Mode)
	{
		_Dev16550[fd].IsRs485 = 0x55;
		_Dev16550[fd]._485line = _485Line;
		if (m_EMIO_Addr == MAP_DEVICE_FAILED)
		{
			m_EMIO_Addr = mmap_device_io(1024, 0xE000A000);
			if (m_EMIO_Addr == MAP_DEVICE_FAILED)
			{
				return -4;
			}
		}
		m_GPIO_Reg = (struct GPIO_Reg *) m_EMIO_Addr;
		m_GPIO_Reg->MASK_DATA_2_LSW &= (~(0x1 << _Dev16550[fd]._485line));
		m_GPIO_Reg->DIRM_2 |= 0x1 << _Dev16550[fd]._485line;
		m_GPIO_Reg->OEN_2 |= 0x1 << _Dev16550[fd]._485line;
		EMIO_RS485Recv(_Dev16550[fd]._485line);
	}
	else
	{
		_Dev16550[fd].IsRs485 = 0;
	}
	_Dev16550[fd].IsItemUsed = 0x55;
	pthread_create(NULL, NULL, Uart550_int_thread, (void*) &_Dev16550[fd]);
	return fd;
}
/**
 * Function:       // Uart16550_Send
 * Description:    // 串口数据发送
 * Input:* int32_t fd ,   //Uart16550_Open 返回的句柄
 * uint8_t*buffer,//待发送数据缓存
 * int32_t len,  //待发送数据长度
 * Output:         // 无
 * Return:         // 正数表示成功放入缓存的数据长度    负数表示异常
 * Others:         //无
 */
int32_t Uart16550_Send(int32_t fd, uint8_t*buffer, int32_t len)
{
	int32_t i;
	if (buffer == NULL || len < 1)
	{
		return -1;
	}
	if (fd >= sizeof(_Dev16550) / sizeof(Dev16550) || fd < 0)
	{
		return -2;
	}
	if (_Dev16550[fd].VirBase == 0)
	{
		printf("(VirBase== 0)\n");
		return -3;
	}
	if (_Dev16550[fd].TxSum + len - _Dev16550[fd].TxPoint
			> sizeof(_Dev16550[fd].TxBuf))
	{
		return 0;
	}
	if (_Dev16550[fd].IsRs485 == 0x55)
	{
		EMIO_RS485Send(_Dev16550[fd]._485line);
		usleep(1000);
	}
	for (i = 0; i < len; i++)
	{
		_Dev16550[fd].TxBuf[_Dev16550[fd].TxSum & TxBufMsk] = *buffer++;
		_Dev16550[fd].TxSum++;
	}
	out32(_Dev16550[fd].VirBase + IER, in32(_Dev16550[fd].VirBase + IER)
			| (0x2));//开发送空中断
	return len;
}
/**
 * Function:       // Uart16550_Close
 * Description:    // 关闭串口
 * Input:* int32_t fd ,   //Uart16550_Open 返回的句柄
 * Output:         // 无
 * Return:         // 无
 * Others:         //无
 */
void Uart16550_Close(int32_t fd)
{
	if (fd >= sizeof(_Dev16550) / sizeof(Dev16550) || fd < 0)
	{
		return;
	}
	if (_Dev16550[fd].VirBase != 0)
	{
		munmap_device_io(_Dev16550[fd].VirBase, 0x1100);
		_Dev16550[fd].VirBase = 0;
		_Dev16550[fd].IsItemUsed = 0;
		_Dev16550[fd].PhyAddress = 0;
	}
}
